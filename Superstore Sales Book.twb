    <worksheet name='Average Shipping Time'>
      <table>
        <view>
          <datasources>
            <datasource caption='CleanedData (cleaned_superstore_dataset)' name='federated.1ssl0lk1726abp147wakw1rkeot3' />
          </datasources>
          <datasource-dependencies datasource='federated.1ssl0lk1726abp147wakw1rkeot3'>
            <column caption='Shipping Days' datatype='integer' name='[Calculation_1954944607522822]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;,[Order Date],[Ship Date])' />
            </column>
            <column caption='Avg Shipping Time' datatype='real' name='[Calculation_1954944607723527]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='AVG([Calculation_1954944607522822])' />
            </column>
            <column caption='Valid Shipping Record' datatype='boolean' name='[Calculation_1954944610254857]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;,[Order Date],[Ship Date]) &gt;= 0' />
            </column>
            <column datatype='date' name='[Order Date]' role='dimension' type='ordinal' />
            <column datatype='date' name='[Ship Date]' role='dimension' type='ordinal' />
            <column-instance column='[Calculation_1954944610254857]' derivation='None' name='[none:Calculation_1954944610254857:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_1954944607723527]' derivation='User' name='[usr:Calculation_1954944607723527:qk]' pivot='key' type='quantitative' />
