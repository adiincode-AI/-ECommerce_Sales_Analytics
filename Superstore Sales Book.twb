      <aliases enabled='yes' />
      <column caption='Total Orders' datatype='integer' name='[Calculation_1954944591192064]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([Order ID])' />
      </column>
      <column caption='Total Customer' datatype='integer' name='[Calculation_1954944594051073]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([Customer ID])' />
      </column>
      <column caption='Average Order Value' datatype='real' name='[Calculation_1954944594829314]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Sales]) / [Calculation_1954944591192064]' />
      </column>
      <column caption='Avg Sales Per Customer' datatype='real' name='[Calculation_1954944596647939]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Sales]) / [Calculation_1954944594051073]' />
      </column>
      <column caption='Shipping Days' datatype='integer' name='[Calculation_1954944607522822]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;,[Order Date],[Ship Date])' />
      </column>
      <column caption='Avg Shipping Time' datatype='real' name='[Calculation_1954944607723527]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Calculation_1954944607522822])' />
      </column>
      <column caption='Valid Shipping Record' datatype='boolean' name='[Calculation_1954944610254857]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;,[Order Date],[Ship Date]) &gt;= 0' />
      </column>
      <column caption='Product Rank' datatype='integer' name='[Calculation_1954944614453259]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK(SUM([Sales]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Top N Filter' datatype='boolean' name='[Calculation_1954944614834188]' role='measure' type='nominal'>
        <calculation class='tableau' formula='RANK(SUM([Sales])) &lt;= [Parameters].[Parameter 1954944614092810]'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Average Sales per Customer' datatype='real' name='[Calculation_2333727065636864]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Sales])/COUNTD([Customer ID])' />
      </column>
      <column caption='Customer First Purchase' datatype='date' name='[Calculation_2333727069577217]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='{ FIXED [Customer ID]: MIN([Order Date]) }' />
      </column>
      <column caption='Customer Type' datatype='string' name='[Calculation_2333727069769730]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='if [Order Date] = [Calculation_2333727069577217]&#13;&#10;THEN &quot;New Customer&quot;&#13;&#10;ELSE &quot;Repeat Customer&quot;&#13;&#10;END' />
      </column>
